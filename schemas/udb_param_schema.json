{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",

  "required": [
    "$schema",
    "kind",
    "description",
    "long_name",
    "definedBy",
    "schema"
  ],
  "properties": {
    "$schema": {
      "const": "udb_param_schema.json#"
    },
    "kind": {
      "const": "parameter"
    },
    "name": {
      "$ref": "udb_schema_defs.json#/$defs/param_name"
    },
    "long_name": {
      "description": "Short description of the parameter",
      "type": "string"
    },
    "description": {
      "$ref": "udb_schema_defs.json#/$defs/spec_text",
      "description": "Parameter description, including list of valid values"
    },
    "definedBy": {
      "description": "Extension requirement condition that must be met for parameter to exist. The condition that the defining extension is implemented is implicit, and does not need to be explicitly listed",
      "$ref": "udb_schema_defs.json#/$defs/condition"
    },
    "schema": {
      "$ref": "udb-json-schema-draft-07.json#",
      "additionalProperties": false
    },
    "requirements": {
      "$ref": "udb_schema_defs.json#/$defs/condition"
    },
    "$source": {
      "type": "string",
      "description": "Source file where this parameter was defined"
    }
  },
  "additionalProperties": false
}

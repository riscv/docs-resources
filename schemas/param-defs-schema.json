{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Schema for parameter definition input files",
  "type": "object",

  "properties": {
    "$schema": {
      "type": "string"
    },
    "chapter_name": {
      "type": "string",
      "description": "Name of chapter (keep it short) in standards document associated with parameter definitions"
    },
    "parameter_definitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "$ref": "param-common-schema.json#/paramName",
            "description": "Single parameter name"
          },
          "names": {
            "$ref": "param-common-schema.json#/paramNameArray",
            "description": "Multiple parameter names"
          },
          "long-name": {
            "type": "string",
            "description": "Long name of the parameter (a few words)"
          },
          "note": {
            "type": "string",
            "$ref": "param-common-schema.json#/noteDesc"
          },
          "description": {
            "type": "string",
            "$ref": "param-common-schema.json#/descriptionDesc"
          },
          "impl-def": {
            "$ref": "param-common-schema.json#/implDefName",
            "description": "Name of implementation-defined behavior"
          },
          "impl-defs": {
            "$ref": "param-common-schema.json#/implDefNameArray",
            "description": "List of implementation-defined behaviors"
          },
          "type": {
            "$ref": "param-common-schema.json#/paramType"
          },
          "range": {
            "$ref": "param-common-schema.json#/paramRange"
          },
          "array": {
            "$ref": "param-common-schema.json#/paramArray"
          },
          "width": {
            "allOf": [
              { "$ref": "param-common-schema.json#/paramWidth" },
              { "$ref": "param-common-schema.json#/paramWidthDesc" }
            ]
          }
        },
        "allOf": [
          {
            "oneOf": [
              { "required": ["type"] },
              { "required": ["range"] }
            ]
          },
          {
            "if": {
              "required": ["width"]
            },
            "then": {
              "properties": {
                "type": {
                  "enum": ["int", "uint"]
                }
              },
              "required": ["type"]
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "enum": ["int", "uint"]
                }
              },
              "required": ["type"]
            },
            "then": {
              "required": ["width"]
            }
          },
          {
            "oneOf": [
              { "required": ["name"] },
              { "required": ["names"] }
            ]
          },
          {
            "not": {
              "required": ["impl-def", "impl-defs"]
            }
          },
          {
            "if": {
              "not": {
                "anyOf": [
                  { "required": ["impl-def"] },
                  { "required": ["impl-defs"] }
                ]
              }
            },
            "then": {
              "required": ["description"]
            }
          }
        ],
        "additionalProperties": false
      }
    },
    "csr_definitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "reg-name": {
            "$ref": "param-common-schema.json#/csrName",
            "description": "Single CSR name"
          },
          "reg-names": {
            "$ref": "param-common-schema.json#/csrNameArray",
            "description": "Multiple CSR names"
          },
          "note": {
            "type": "string",
            "$ref": "param-common-schema.json#/noteDesc"
          },
          "description": {
            "type": "string",
            "$ref": "param-common-schema.json#/descriptionDesc"
          },
          "field-name": {
            "$ref": "param-common-schema.json#/csrName",
            "description": "Single CSR field name"
          },
          "func-of-reg-name": {
            "$ref": "param-common-schema.json#/funcOfRegName"
          },
          "func-of-field-name": {
            "$ref": "param-common-schema.json#/funcOfFieldName"
          },
          "field-names": {
            "$ref": "param-common-schema.json#/csrNameArray",
            "description": "Multiple CSR field names"
          },
          "type": {
            "allOf": [
              { "$ref": "param-common-schema.json#/csrType" },
              { "$ref": "param-common-schema.json#/csrTypeDesc" }
            ]
          },
          "width-parameter": {
            "allOf": [
              { "$ref": "param-common-schema.json#/paramName" },
              { "$ref": "param-common-schema.json#/csrWidthParameterDesc" }
            ]
          },
          "impl-def": {
            "$ref": "param-common-schema.json#/implDefName",
            "description": "Name of implementation-defined behavior"
          },
          "impl-defs": {
            "$ref": "param-common-schema.json#/implDefNameArray",
            "description": "List of implementation-defined behaviors"
          }
        },
        "allOf": [
          {
            "oneOf": [
              { "required": ["reg-name"] },
              { "required": ["reg-names"] }
            ]
          },
          {
            "not": {
              "required": ["field-name", "field-names"]
            }
          },
          {
            "required": ["type"]
          },
          {
            "if": {
              "properties": {
                "type": { "const": "VarWidth" }
              },
              "required": ["type"]
            },
            "then": {
              "required": ["width-parameter"]
            },
            "else": {
              "not": {
                "required": ["width-parameter"]
              }
            }
          },
          {
            "not": {
              "required": ["impl-def", "impl-defs"]
            }
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "required": ["$schema", "chapter_name"],
  "anyOf": [
    { "required": ["parameter_definitions"] },
    { "required": ["csr_definitions"] }
  ],
  "additionalProperties": false
}

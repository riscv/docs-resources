{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Schema for params.json",
  "type": "object",

  "properties": {
    "parameters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "name": {
           "type": "string",
           "description": "Parameter name"
          },
          "def_filename": {
            "type": "string",
            "description": "Parameter definition file that defines this parameter"
          },
          "chapter_name": {
            "type": "string",
            "description": "Parameters for specified chapter in standards document"
          },
          "note": {
            "type": "string",
            "$ref": "param-common-schema.json#/noteDesc"
          },
          "description": {
            "type": "string",
            "$ref": "param-common-schema.json#/descriptionDesc"
          },
          "type": {
            "$ref": "param-common-schema.json#/paramType"
          },
          "range": {
            "$ref": "param-common-schema.json#/paramRange"
          },
          "array": {
            "$ref": "param-common-schema.json#/paramArray"
          },
          "width": {
            "allOf": [
              { "$ref": "param-common-schema.json#/paramWidth" },
              { "$ref": "param-common-schema.json#/paramWidthDesc" }
            ]
          },
          "json-schema": {
            "type": "object",
            "description": "JSON Schema equivalent of the type or range property"
          },
          "impl-defs": {
            "allOf": [
              {
                "type": "array",
                "items": {
                  "$ref": "norm-rules-schema.json#/definitions/normativeRuleEntry"
                },
                "minItems": 1
              },
              { "$ref": "param-common-schema.json#/implDefBehaviorDesc" }
            ]
          }
        },
        "required": ["name", "def_filename", "chapter_name", "json-schema"],
        "allOf": [
          {
            "oneOf": [
              { "required": ["type"] },
              { "required": ["range"] }
            ]
          },
          {
            "if": {
              "required": ["width"]
            },
            "then": {
              "properties": {
                "type": {
                  "enum": ["int", "uint"]
                }
              },
              "required": ["type"]
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "enum": ["int", "uint"]
                }
              },
              "required": ["type"]
            },
            "then": {
              "required": ["width"]
            }
          }
        ],
        "additionalProperties": false
      }
    },
    "csrs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "reg-name": {
           "type": "string",
           "description": "CSR name"
          },
          "field-name": {
            "type": "string",
            "description": "CSR field name"
          },
          "def_filename": {
            "type": "string",
            "description": "Parameter definition file that defines this CSR"
          },
          "chapter_name": {
            "type": "string",
            "description": "CSRs for specified chapter in standards document"
          },
          "note": {
            "type": "string",
            "$ref": "param-common-schema.json#/noteDesc"
          },
          "description": {
            "type": "string",
            "$ref": "param-common-schema.json#/descriptionDesc"
          },
          "category": {
            "$ref": "param-common-schema.json#/csrCategory",
            "description": "CSR category"
          },
          "enum": {
            "$ref": "param-common-schema.json#/csrEnumOutput",
            "description": "CSR legal values and illegal-write behavior"
          },
          "width": {
            "$ref": "param-common-schema.json#/paramName",
            "description": "Name of a parameter that provides the bit width"
          },
          "ro-mask": {
            "type": "integer",
            "description": "Decimal integer mask specifying read-only bits"
          },
          "ro-value": {
            "type": "integer",
            "description": "Decimal integer value of read-only bits"
          },
          "impl-defs": {
            "allOf": [
              {
                "type": "array",
                "items": {
                  "$ref": "norm-rules-schema.json#/definitions/normativeRuleEntry"
                },
                "minItems": 1
              },
              { "$ref": "param-common-schema.json#/implDefBehaviorDesc" }
            ]
          }
        },
        "required": ["reg-name", "def_filename", "chapter_name", "category"],
        "allOf": [
          {
            "if": {
              "required": ["ro-value"]
            },
            "then": {
              "required": ["ro-mask"]
            }
          },
          {
            "not": {
              "anyOf": [
                { "required": ["enum", "width"] },
                { "required": ["enum", "ro-mask"] },
                { "required": ["width", "ro-mask"] }
              ]
            }
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "anyOf": [
    { "required": ["parameters"] },
    { "required": ["csrs"] }
  ],
  "additionalProperties": false
}

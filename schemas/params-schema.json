{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Schema for params.json",
  "type": "object",

  "properties": {
    "parameters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "name": {
           "$ref": "param-common-schema.json#/paramName",
           "description": "Parameter name (all uppercase with underscores for separators)"
          },
          "long-name": {
            "type": "string",
            "description": "Long name of the parameter (a few words)"
          },
          "def_filename": {
            "type": "string",
            "description": "Parameter definition file that defines this parameter"
          },
          "chapter_name": {
            "type": "string",
            "description": "Parameters for specified chapter in standards document"
          },
          "note": {
            "type": "string",
            "$ref": "param-common-schema.json#/noteDesc"
          },
          "description": {
            "type": "string",
            "$ref": "param-common-schema.json#/descriptionDesc"
          },
          "type": {
            "$ref": "param-common-schema.json#/paramType"
          },
          "range": {
            "$ref": "param-common-schema.json#/paramRange"
          },
          "array": {
            "$ref": "param-common-schema.json#/paramArray"
          },
          "width": {
            "allOf": [
              { "$ref": "param-common-schema.json#/paramWidth" },
              { "$ref": "param-common-schema.json#/paramWidthDesc" }
            ]
          },
          "json-schema": {
            "type": "object",
            "description": "JSON Schema equivalent of the type or range property"
          },
          "impl-defs": {
            "allOf": [
              {
                "type": "array",
                "items": {
                  "$ref": "norm-rules-schema.json#/definitions/normativeRuleEntry"
                },
                "minItems": 1
              },
              { "$ref": "param-common-schema.json#/implDefBehaviorDesc" }
            ]
          }
        },
        "required": ["name", "long-name", "def_filename", "chapter_name", "json-schema"],
        "allOf": [
          {
            "oneOf": [
              { "required": ["type"] },
              { "required": ["range"] }
            ]
          },
          {
            "if": {
              "required": ["width"]
            },
            "then": {
              "properties": {
                "type": {
                  "enum": ["int", "uint"]
                }
              },
              "required": ["type"]
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "enum": ["int", "uint"]
                }
              },
              "required": ["type"]
            },
            "then": {
              "required": ["width"]
            }
          }
        ],
        "additionalProperties": false
      }
    },
    "csrs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "reg-name": {
           "type": "string",
           "description": "CSR name"
          },
          "field-name": {
            "type": "string",
            "description": "CSR field name"
          },
          "func-of-reg-name": {
            "$ref": "param-common-schema.json#/funcOfRegName"
          },
          "func-of-field-name": {
            "$ref": "param-common-schema.json#/funcOfFieldName"
          },
          "def_filename": {
            "type": "string",
            "description": "Parameter definition file that defines this CSR"
          },
          "chapter_name": {
            "type": "string",
            "description": "CSRs for specified chapter in standards document"
          },
          "note": {
            "type": "string",
            "$ref": "param-common-schema.json#/noteDesc"
          },
          "description": {
            "type": "string",
            "$ref": "param-common-schema.json#/descriptionDesc"
          },
          "category": {
            "$ref": "param-common-schema.json#/csrCategory",
            "description": "CSR category"
          },
          "type": {
            "allOf": [
              { "$ref": "param-common-schema.json#/csrType" },
              { "$ref": "param-common-schema.json#/csrTypeDesc" }
            ]
          },
          "width-parameter": {
            "allOf": [
              { "$ref": "param-common-schema.json#/paramName" },
              { "$ref": "param-common-schema.json#/csrWidthParameterDesc" }
            ]
          },
          "impl-defs": {
            "allOf": [
              {
                "type": "array",
                "items": {
                  "$ref": "norm-rules-schema.json#/definitions/normativeRuleEntry"
                },
                "minItems": 1
              },
              { "$ref": "param-common-schema.json#/implDefBehaviorDesc" }
            ]
          }
        },
        "required": ["reg-name", "long-name", "def_filename", "chapter_name", "category", "type"],
        "allOf": [
          {
            "if": {
              "properties": {
                "type": { "const": "VarWidth" }
              },
              "required": ["type"]
            },
            "then": {
              "required": ["width-parameter"]
            },
            "else": {
              "not": {
                "required": ["width-parameter"]
              }
            }
          },
          {
            "if": {
              "required": ["func-of-field-name"]
            },
            "then": {
              "required": ["func-of-reg-name"]
            }
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "anyOf": [
    { "required": ["parameters"] },
    { "required": ["csrs"] }
  ],
  "additionalProperties": false
}
